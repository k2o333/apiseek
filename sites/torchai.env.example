# Copy to sites/torchai.env and: chmod 600 sites/torchai.env
MONITOR_SITE_ID=torchai
MONITOR_BASE_URL=https://torchai.ai
MONITOR_USERNAME=
MONITOR_PASSWORD=
REQUIRE_NEW_API_USER_HEADER=1
# CONNECT_TIMEOUT_SECONDS=5
# READ_TIMEOUT_SECONDS=20
# MONITOR_PROXY_URL=
# After models bootstrap: set 1 so groups poll does T-new for true new groups
# MONITOR_MODELS_INCREMENTAL_ENABLE=1
LOG_LEVEL=INFO

# Optional: business rate = rate_multiplier / MONITOR_RATE_DIVISOR (default 1).
# pinaic / hubway should set 10 (e.g. raw 16 -> effective 1.6).
# MONITOR_RATE_DIVISOR=1
