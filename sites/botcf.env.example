# Copy to sites/botcf.env and: chmod 600 sites/botcf.env
MONITOR_SITE_ID=botcf
MONITOR_BASE_URL=https://botcf.com
MONITOR_USERNAME=
MONITOR_PASSWORD=
REQUIRE_NEW_API_USER_HEADER=0
# CONNECT_TIMEOUT_SECONDS=5
# READ_TIMEOUT_SECONDS=20
# MONITOR_PROXY_URL=
LOG_LEVEL=INFO

# Optional: business rate = rate_multiplier / MONITOR_RATE_DIVISOR (default 1).
# pinaic / hubway should set 10 (e.g. raw 16 -> effective 1.6).
# MONITOR_RATE_DIVISOR=1
