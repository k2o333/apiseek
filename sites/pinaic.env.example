# Copy to sites/pinaic.env and protect with: chmod 600 sites/pinaic.env
MONITOR_SITE_ID=pinaic
MONITOR_SITE_NAME=PinAI
MONITOR_BASE_URL=https://app.pinaic.com
MONITOR_USERNAME=your_email@example.com
MONITOR_PASSWORD=your_password

MONITOR_LOGIN_PATH=/api/v1/auth/login
MONITOR_REFRESH_PATH=/api/v1/auth/refresh
MONITOR_GROUPS_PATH=/api/v1/groups/available
MONITOR_USERNAME_FIELD=email

POLL_INTERVAL_SECONDS=300
CONNECT_TIMEOUT_SECONDS=10
READ_TIMEOUT_SECONDS=30
REFRESH_MARGIN_SECONDS=600
REQUEST_JITTER_SECONDS=10
DATA_DIR=/root/projects/zhongzhuan/data/pinaic
TOKEN_STATE_FILE=/root/projects/zhongzhuan/data/pinaic/token.json
# Optional supported-region HTTP(S) proxy, for example: http://host:port
MONITOR_PROXY_URL=
LOG_LEVEL=INFO

# Optional: business rate = rate_multiplier / MONITOR_RATE_DIVISOR (default 1).
# pinaic / hubway should set 10 (e.g. raw 16 -> effective 1.6).
MONITOR_RATE_DIVISOR=10
