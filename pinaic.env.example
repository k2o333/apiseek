# Copy this file to pinaic.env and protect it with: chmod 600 pinaic.env
MONITOR_SITE_NAME=PINAIC
MONITOR_BASE_URL=https://app.pinaic.com
MONITOR_USERNAME=your_email@example.com
MONITOR_PASSWORD=your_password
MONITOR_USERNAME_FIELD=email
MONITOR_LOGIN_PATH=/api/v1/auth/login
MONITOR_GROUPS_PATH=/api/v1/groups/available

# Optional supported-region HTTP(S) proxy, for example: http://host:port
# MONITOR_PROXY_URL=

POLL_INTERVAL_SECONDS=300
DATA_DIR=/root/projects/zhongzhuan/data/pinaic
TOKEN_STATE_FILE=/root/projects/zhongzhuan/data/pinaic/token_state.json
LOG_LEVEL=INFO
