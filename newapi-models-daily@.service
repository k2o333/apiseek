[Unit]
Description=New-API daily model inventory refresh for %i
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/root/projects/zhongzhuan
ExecStart=/root/projects/zhongzhuan/.venv/bin/python /root/projects/zhongzhuan/newapi_monitor.py --env-file /root/projects/zhongzhuan/sites/%i.env --models-refresh
TimeoutStartSec=600

