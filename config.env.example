# Copy this file to config.env and protect it with: chmod 600 config.env
AIAPIBANK_EMAIL=your_email@example.com
AIAPIBANK_PASSWORD=your_password

# Poll every five minutes.
POLL_INTERVAL_SECONDS=300
DATA_DIR=/root/projects/zhongzhuan/data
TOKEN_STATE_FILE=/root/projects/zhongzhuan/data/token_state.json
LOG_LEVEL=INFO
